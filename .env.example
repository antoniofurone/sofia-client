# ── Mode ──────────────────────────────────────────────────────────────────────
# VITE_MODE: 'debug' keeps the original dev UI with manual agent URL.
# 'production' activates the production UI (agent dropdown, auth, DB).
VITE_MODE=debug

# ── Authentication (only used when VITE_MODE=production) ──────────────────────
# VITE_AUTH_MODE options:
#   none  → no login required; all agents in sf_agents_config are accessible
#   app   → app-to-app auth (external app calls /api/auth/app-login to get token)
#   user  → user/password login form
VITE_AUTH_MODE=none

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Session (required when VITE_MODE=production and VITE_AUTH_MODE != none) ──
SESSION_SECRET=replace-this-with-a-long-random-string
SESSION_TIMEOUT_MINUTES=30

# ── PostgreSQL (required when VITE_MODE=production) ──────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sofia
DB_USER=postgres
DB_PASSWORD=
