{
  "name": "sofia-client",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:server": "ts-node-dev --respawn --transpile-only --exit-child --project server/tsconfig.json server/src/index.ts",
    "build": "vite build",
    "server:build": "tsc -p server/tsconfig.json",
    "build:all": "npm run build && npm run server:build",
    "start": "node server/dist/index.js",
    "preview": "vite preview",
    "db:migrate": "psql -d $npm_config_db -f server/migrations/001_init.sql"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "connect-pg-simple": "^9.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "dompurify": "^3.4.1",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "marked": "^18.0.2",
    "pg": "^8.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.17",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3",
    "undici": "^6.21.0",
    "vite": "^6.0.3"
  }
}
